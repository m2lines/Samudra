# syntax=docker/dockerfile:1.7
FROM nvcr.io/nvidia/physicsnemo/physicsnemo:26.05

WORKDIR /workspace

ARG VCS_REF=unknown
ARG VCS_URL=unknown
ARG BUILD_DATE=unknown
ARG NSYS_CLI_AMD64_DEB_URL="https://developer.download.nvidia.com/devtools/nsight-systems/NsightSystems-linux-cli-public-2026.1.1.204-3717666.deb"
ARG NSYS_CLI_ARM64_DEB_URL="https://developer.download.nvidia.com/devtools/nsight-systems/nsight-systems-cli-2026.1.1_2026.1.1.204-1_arm64.deb"
ARG TARGETARCH

LABEL org.opencontainers.image.revision="${VCS_REF}" \
      org.opencontainers.image.source="${VCS_URL}" \
      org.opencontainers.image.created="${BUILD_DATE}"

ENV SAMUDRA_CONTAINER_GIT_COMMIT="${VCS_REF}" \
    SAMUDRA_CONTAINER_GIT_REMOTE_URL="${VCS_URL}" \
    WANDB_GIT_COMMIT="${VCS_REF}" \
    WANDB_GIT_REMOTE_URL="${VCS_URL}" \
    WANDB_DISABLE_GIT=true

# Upgrade to a newer Nsight Systems CLI build so `--trace=nccl` is available.
# NVIDIA publishes different Debian packages for amd64 and arm64.
RUN apt-get update \
    && target_arch="${TARGETARCH:-$(dpkg --print-architecture)}" \
    && case "${target_arch}" in \
        amd64|x86_64) NSYS_CLI_DEB_URL="${NSYS_CLI_AMD64_DEB_URL}" ;; \
        arm64|aarch64) NSYS_CLI_DEB_URL="${NSYS_CLI_ARM64_DEB_URL}" ;; \
        *) echo "Unsupported TARGETARCH=${target_arch} for Nsight Systems CLI install" >&2; exit 1 ;; \
       esac \
    && apt-get install -y --no-install-recommends ca-certificates curl \
    && curl -fsSL "${NSYS_CLI_DEB_URL}" -o /tmp/nsight-systems-cli.deb \
    && apt-get install -y --no-install-recommends /tmp/nsight-systems-cli.deb \
    && rm -f /tmp/nsight-systems-cli.deb \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/local/bin/nsys /usr/local/cuda/bin/nsys \
    && nsys --version

COPY LICENSE README.md pyproject.toml rust-toolchain.toml uv.lock ./
COPY .cargo ./.cargo
COPY src ./src
COPY configs ./configs
COPY tests ./tests
COPY rust/crab_load ./rust/crab_load
COPY scripts/container ./scripts/container

# Bind-mount targets used by Slurm harnesses (ensure they exist in the image so
# Apptainer --bind doesn't fail when mounting into subpaths).
RUN mkdir -p /workspace/.data_cache

# Ensure image-provided heavy deps satisfy this project's declared requirements.
RUN python scripts/container/verify_image_packages.py

# Reuse image-provided torch stack via system site-packages at runtime.
RUN uv venv .venv --python /usr/bin/python3 --system-site-packages

# Keep torch/torchvision/flash-attn from the base image; install the rest with uv.
# Build the local Rust extension with a pinned, temporary toolchain. This is a
# development container, so include dev dependencies too.
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
        | sh -s -- -y --profile minimal --default-toolchain none \
    && . /root/.cargo/env \
    && rustup toolchain install \
    && . .venv/bin/activate \
    && uv sync --frozen --active --extra cuda --extra rust \
        --no-install-package torch \
        --no-install-package torchvision \
        --no-install-package flash-attn \
        --no-install-package nvidia-cublas-cu12 \
        --no-install-package nvidia-cuda-cupti-cu12 \
        --no-install-package nvidia-cuda-nvrtc-cu12 \
        --no-install-package nvidia-cuda-runtime-cu12 \
        --no-install-package nvidia-cudnn-cu12 \
        --no-install-package nvidia-cufft-cu12 \
        --no-install-package nvidia-cufile-cu12 \
        --no-install-package nvidia-curand-cu12 \
        --no-install-package nvidia-cusolver-cu12 \
        --no-install-package nvidia-cusparse-cu12 \
        --no-install-package nvidia-cusparselt-cu12 \
        --no-install-package nvidia-nccl-cu12 \
        --no-install-package nvidia-nvjitlink-cu12 \
        --no-install-package nvidia-nvshmem-cu12 \
        --no-install-package nvidia-nvtx-cu12 \
        --no-install-package nvidia-cublas \
        --no-install-package nvidia-cuda-cupti \
        --no-install-package nvidia-cuda-nvrtc \
        --no-install-package nvidia-cuda-runtime \
        --no-install-package nvidia-cudnn-cu13 \
        --no-install-package nvidia-cufft \
        --no-install-package nvidia-cufile \
        --no-install-package nvidia-curand \
        --no-install-package nvidia-cusolver \
        --no-install-package nvidia-cusparse \
        --no-install-package nvidia-cusparselt-cu13 \
        --no-install-package nvidia-nccl-cu13 \
        --no-install-package nvidia-nvjitlink \
        --no-install-package nvidia-nvshmem-cu13 \
        --no-install-package nvidia-nvtx \
        --no-install-package triton \
    && rm -rf /root/.cargo /root/.rustup rust/crab_load/target

RUN . .venv/bin/activate \
    && python scripts/container/smoke_test.py

CMD ["/bin/bash"]
