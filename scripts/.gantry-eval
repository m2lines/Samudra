# This currently does not work
#!/bin/bash

set -e

JOB_NAME="samudra-evaluator-instancenorm"  # recommended but not required to change this
CONFIG_PATH=configs/gantry_eval_cm4.yaml  # relative to the root of the repository
EXISTING_RESULTS_DATASET="01JMKEF5P89ZWZMEH5G6263K9N"  # this contains the checkpoint to use for inference

echo 'Using config file:' $CONFIG_PATH
 # since we use a service account API key for wandb, we use the beaker username to set the wandb username
BEAKER_USERNAME=suryad
N_GPUS=1

gantry run \
    --name $JOB_NAME \
    --description 'Evaluating Samudra with CM4' \
    --workspace ai2/ace \
    --priority normal \
    --cluster ai2/saturn-cirrascale \
    --cluster ai2/jupiter-cirrascale-2 \
    --cluster ai2/ceres-cirrascale \
    --env GOOGLE_APPLICATION_CREDENTIALS=/tmp/google_application_credentials.json \
    --env-secret WANDB_API_KEY=wandb-api-key-ai2cm-sa \
    --dataset-secret google-credentials:/tmp/google_application_credentials.json \
    --dataset jamesd/2025-01-20-cm4-ocean-piControl-200yr-dataset-stats:/statsdata \
    --dataset $EXISTING_RESULTS_DATASET:2025-02-20-train-samudra-train-cm4-thermodynamic-ema-decay0.999-lr1e-4-nosched-fusedopt-instancenorm/saved_nets/best_inference_ckpt.pt:/ckpt.pt \
    --gpus $N_GPUS \
    --shared-memory 200GiB \
    --weka climate-default:/climate-default \
    --budget ai2/climate \
    --beaker-image 'ai2/pytorch2.0.0-cuda11.8-python3.10' \
    --venv 'base' \
    --install "pip install -r requirements.txt" \
    -- python src/eval.py --config $CONFIG_PATH --subname $JOB_NAME