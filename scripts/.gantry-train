
#!/bin/bash

set -e

git branch -r --contains $(git rev-parse HEAD) | grep -q . || { echo "Error: Commit not found on remote."; exit 1; }
SCRIPT_PATH=$(git rev-parse --show-prefix)  # relative to the root of the repository

JOB_NAME="samudra-train-cm4-thermodynamic-instancenorm-ema-ohc-corrector"  # recommended but not required to change this
CONFIG_PATH="configs/gantry_train_cm4.yaml"

echo 'Using config file:' $CONFIG_PATH
 # since we use a service account API key for wandb, we use the beaker username to set the wandb username
BEAKER_USERNAME=$(beaker account whoami --format=json | jq -r '.[0].name')
WANDB_USERNAME=suryad
N_GPUS=8
REPO_ROOT=$(git rev-parse --show-toplevel)

cd $REPO_ROOT

gantry run \
    --name $JOB_NAME \
    --description 'Training Samudra with CM4' \
    --workspace ai2/ace \
    --priority high \
    --not-preemptible \
    --cluster ai2/saturn-cirrascale \
    --cluster ai2/jupiter-cirrascale-2 \
    --cluster ai2/ceres-cirrascale \
    --env WANDB_USERNAME=$WANDB_USERNAME \
    --env WANDB_NAME=$JOB_NAME \
    --env WANDB_JOB_TYPE=training \
    --env GOOGLE_APPLICATION_CREDENTIALS=/tmp/google_application_credentials.json \
    --env-secret WANDB_API_KEY=wandb-api-key-ai2cm-sa \
    --dataset-secret google-credentials:/tmp/google_application_credentials.json \
    --dataset jamesd/2025-01-20-cm4-ocean-piControl-200yr-dataset-stats:/statsdata \
    --gpus $N_GPUS \
    --shared-memory 500GiB \
    --weka climate-default:/climate-default \
    --budget ai2/climate \
    --beaker-image 'ai2/pytorch2.0.0-cuda11.8-python3.10' \
    --venv 'base' \
    --install "pip install uv" \
    -- uv run torchrun --nproc_per_node $N_GPUS src/ocean_emulators/train.py --config $CONFIG_PATH --subname $JOB_NAME
