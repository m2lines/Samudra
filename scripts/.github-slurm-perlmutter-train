
#!/bin/bash

set -e

if [[ -z $(git status --porcelain) ]]; then
    echo "Working directory is clean."
else
    echo "There are uncommitted changes."
    git status --porcelain
    exit 1
fi

git branch -r --contains $(git rev-parse HEAD) | grep -q . || { echo "Error: Commit not found on remote."; exit 1; }
