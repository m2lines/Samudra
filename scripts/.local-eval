#!/bin/bash

# Assumes you have activated the emulator conda environment and
# set the CLUSTER_NAME and OCEAN_DATA_DIR environment variables
set -e
CONFIG_PATH=configs/eval_cm4.yaml

echo 'Running local training on cluster:' $CLUSTER_NAME 'with data directory:' $OCEAN_DATA_DIR
echo 'Using config file:' $CONFIG_PATH

# current date
DATE=$(date +%Y-%m-%d)

uv run src/ocean_emulators/eval.py \
    $CONFIG_PATH \
    --ckpt_path /pscratch/sd/s/suryad/Ocean_Emulator/train/2025-04-28-samudra-traincm4-thermodynamic-instancenorm-finetune-ohc-corrector-nohfdschange/saved_nets/best_inference_ckpt.pt \
    --experiment.cluster_data_dir $OCEAN_DATA_DIR \
    --experiment.name "${DATE}-cm4-ohc-finetuned-nohfdschange-120" \
    --save_zarr true