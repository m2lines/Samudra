#!/bin/bash
#SBATCH --job-name=samudra-train
#SBATCH --output=slurm-%j.out
#SBATCH --error=slurm-%j.err
#SBATCH --constraint=gpu&hbm80g
#SBATCH --account=m4874
#SBATCH --qos=debug
#SBATCH --mem=110G
#SBATCH --nodes=1
#SBATCH --gres=gpu:1
#SBATCH --ntasks-per-node=1
#SBATCH --time=00:20:00

set -e

module load conda
conda activate emulator

CONFIG_PATH=configs/slurm_train_cm4_thermo.yaml

echo 'Running SLURM on cluster:' $CLUSTER_NAME 'with data directory:' $OCEAN_DATA_DIR
echo 'Using config file:' $CONFIG_PATH

# Create a temporary config file with updated cluster_data_dir
TMP_CONFIG_PATH=/tmp/config_temp.yaml
sed "s|cluster_data_dir:.*|cluster_data_dir: $OCEAN_DATA_DIR|" $CONFIG_PATH > $TMP_CONFIG_PATH

# Get the first node as the master node
export MASTER_ADDR=$(scontrol show hostnames "$SLURM_JOB_NODELIST" | head -n 1)
export MASTER_PORT=29400

# Run the training script
srun torchrun \
    --nnodes=1 \
    --nproc_per_node=2 \
    --rdzv_backend=c10d \
    --rdzv_endpoint=$MASTER_ADDR:$MASTER_PORT \
    src/train_3D.py \
    --config $TMP_CONFIG_PATH